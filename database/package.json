{
  "name": "traveloop-database",
  "version": "1.0.0",
  "description": "Database layer for Traveloop",
  "main": "index.js",
  "scripts": {
    "db:migrate": "npx ts-node scripts/migrate.ts",
    "db:generate": "npx ts-node scripts/generate-client.ts",
    "db:validate": "npx ts-node scripts/validate-schema.ts",
    "db:seed": "npx ts-node scripts/seed.ts",
    "db:reset": "npx prisma migrate reset --force",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.12",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
