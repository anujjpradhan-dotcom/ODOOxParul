datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// User & Authentication Models
// ==========================================

/// User model representing an app user or admin
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  avatar             String?
  languagePreference String   @default("en")
  isAdmin            Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  refreshTokens      RefreshToken[]
  savedDestinations  SavedDestination[]
  trips              Trip[]
  packingItems       PackingItem[]      @relation("UserPackingItems")
}

/// Refresh token for authentication
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

/// Saved destinations (wishlist)
model SavedDestination {
  id        String   @id @default(cuid())
  userId    String
  cityId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
}

// ==========================================
// Trip & Itinerary Core Models
// ==========================================

enum TripStatus {
  DRAFT
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

/// Trip model representing a user's travel plan
model Trip {
  id            String     @id @default(cuid())
  userId        String
  name          String
  description   String?
  coverImageUrl String?
  startDate     DateTime
  endDate       DateTime   // Application logic must validate endDate > startDate
  status        TripStatus @default(DRAFT)
  isPublic      Boolean    @default(false)
  shareSlug     String?    @unique
  totalBudget   Float?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops        TripStop[]
  notes        TripNote[]
  packingItems PackingItem[]

  @@index([userId])
  @@index([shareSlug])
}

/// TripStop model representing a stop within a trip
model TripStop {
  id            String   @id @default(cuid())
  tripId        String
  cityId        String
  orderIndex    Int
  arrivalDate   DateTime
  departureDate DateTime
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city       City           @relation(fields: [cityId], references: [id])
  activities TripActivity[]
  expenses   Expense[]
  notesRel   TripNote[]

  @@index([tripId, orderIndex])
}

// ==========================================
// City & Activity Reference Data Models
// ==========================================

enum CostLevel {
  BUDGET
  MODERATE
  EXPENSIVE
  LUXURY
}

enum ActivityCategory {
  SIGHTSEEING
  FOOD_TOUR
  ADVENTURE
  CULTURE
  SHOPPING
  NIGHTLIFE
  NATURE
  RELAXATION
  TRANSPORTATION
  OTHER
}

/// City catalog reference data
model City {
  id               String    @id @default(cuid())
  name             String
  country          String
  region           String?
  description      String?
  imageUrl         String?
  costIndex        CostLevel
  popularityScore  Int       @default(0)
  latitude         Float?
  longitude        Float?
  averageDailyCost Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  activities        Activity[]
  tripStops         TripStop[]
  savedDestinations SavedDestination[]

  @@unique([name, country])
  @@index([country])
  @@index([name, country])
}

/// Activity catalog reference data
model Activity {
  id                       String           @id @default(cuid())
  cityId                   String
  name                     String
  description              String?
  imageUrl                 String?
  category                 ActivityCategory
  estimatedCost            Float
  estimatedDurationMinutes Int
  isPopular                Boolean          @default(false)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  city           City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  tripActivities TripActivity[]

  @@index([cityId, category])
}

/// TripActivity representing scheduled activities at a trip stop
model TripActivity {
  id             String   @id @default(cuid())
  tripStopId     String
  activityId     String
  scheduledDate  DateTime?
  scheduledTime  String?
  customCost     Float?
  notes          String?
  orderIndex     Int      @default(0)
  isCompleted    Boolean  @default(false)
  createdAt      DateTime @default(now())

  tripStop TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([tripStopId, activityId])
  @@index([tripStopId, orderIndex])
}

// ==========================================
// Budget, Expenses & Packing Models
// ==========================================

enum ExpenseCategory {
  TRANSPORT
  ACCOMMODATION
  FOOD
  ACTIVITY
  SHOPPING
  MISCELLANEOUS
}

/// Expense model for tracking trip costs
model Expense {
  id          String          @id @default(cuid())
  tripStopId  String
  category    ExpenseCategory
  description String
  amount      Float           // Application logic must validate amount > 0
  currency    String          @default("USD")
  date        DateTime
  createdAt   DateTime        @default(now())

  tripStop TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)

  @@index([tripStopId, category])
}

enum PackingCategory {
  CLOTHING
  DOCUMENTS
  ELECTRONICS
  TOILETRIES
  MEDICATION
  ACCESSORIES
  OTHER
}

/// Packing item model
model PackingItem {
  id        String          @id @default(cuid())
  tripId    String
  userId    String?
  name      String
  category  PackingCategory
  isPacked  Boolean         @default(false)
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation("UserPackingItems", fields: [userId], references: [id])

  @@index([tripId, category])
}

/// TripNote model for general trip notes
model TripNote {
  id         String   @id @default(cuid())
  tripId     String
  tripStopId String?
  title      String?
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripStop TripStop? @relation(fields: [tripStopId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}
